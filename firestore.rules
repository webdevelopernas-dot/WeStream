rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidStream(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.streamerId is string &&
             data.status in ['live', 'offline', 'scheduled'] &&
             data.type in ['live', 'video'] &&
             data.inviteCode is string;
    }

    function isValidMessage(data) {
      return data.streamId is string &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500;
    }

    // Streams collection
    match /streams/{streamId} {
      // Anyone with the invite code can read
      allow read: if true; 
      
      // Only authenticated streamers can create/update their own streams
      allow create: if isAuthenticated() && isValidStream(request.resource.data) && request.resource.data.streamerId == request.auth.uid;
      allow update: if isAuthenticated() && isValidStream(request.resource.data) && resource.data.streamerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.streamerId == request.auth.uid;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if true;
        allow create: if isValidMessage(request.resource.data);
        allow update, delete: if false;
      }
    }

    // User destinations
    match /users/{userId}/destinations/{destId} {
      allow read, write: if isOwner(userId);
    }
  }
}
